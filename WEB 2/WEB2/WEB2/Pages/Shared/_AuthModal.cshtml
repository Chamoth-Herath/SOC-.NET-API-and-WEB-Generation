<style>
    #authOverlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(4px);
        z-index: 2000;
        align-items: center;
        justify-content: center;
    }

        #authOverlay.open {
            display: flex;
        }

    .auth-card {
        background: #fff;
        border-radius: 20px;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 24px 64px rgba(107,26,26,0.22);
        overflow: hidden;
        animation: slideUp 0.28s cubic-bezier(0.34,1.56,0.64,1);
        position: relative;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(32px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .auth-close {
        position: absolute;
        top: 14px;
        right: 16px;
        background: none;
        border: none;
        font-size: 1.2rem;
        color: #aaa;
        cursor: pointer;
        z-index: 10;
    }

        .auth-close:hover {
            color: #333;
        }

    .auth-tabs {
        display: flex;
        border-bottom: 2px solid #f0e8e8;
    }

    .auth-tab {
        flex: 1;
        padding: 18px 0 16px;
        text-align: center;
        font-size: 0.92rem;
        font-weight: 600;
        color: #bbb;
        cursor: pointer;
        border: none;
        background: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: color 0.2s, border-color 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .auth-tab.active {
            color: #6b1a1a;
            border-bottom-color: #6b1a1a;
        }

    .auth-panels {
        padding: 26px 34px 30px;
    }

    .auth-panel {
        display: none;
    }

        .auth-panel.active {
            display: block;
        }

        .auth-panel h2 {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: #6b1a1a;
            margin: 0 0 4px;
        }

        .auth-panel p.sub {
            font-size: 0.82rem;
            color: #999;
            margin: 0 0 20px;
        }

    .role-toggle {
        display: flex;
        background: #f9f0f0;
        border-radius: 10px;
        padding: 4px;
        gap: 4px;
        margin-bottom: 18px;
    }

    .role-btn {
        flex: 1;
        padding: 8px 0;
        border-radius: 8px;
        border: none;
        background: transparent;
        font-size: 0.82rem;
        font-weight: 600;
        color: #bbb;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        font-family: 'DM Sans', sans-serif;
    }

        .role-btn.active {
            background: #fff;
            color: #6b1a1a;
            box-shadow: 0 1px 6px rgba(107,26,26,0.12);
        }

    .auth-group {
        margin-bottom: 12px;
    }

        .auth-group label {
            display: block;
            font-size: 0.72rem;
            font-weight: 600;
            color: #666;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .auth-group input {
            width: 100%;
            padding: 10px 13px;
            border: 1.5px solid #e8d8d8;
            border-radius: 9px;
            font-size: 0.88rem;
            color: #222;
            background: #fdf8f8;
            outline: none;
            transition: border-color 0.2s;
            box-sizing: border-box;
            font-family: 'DM Sans', sans-serif;
        }

            .auth-group input:focus {
                border-color: #6b1a1a;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(107,26,26,0.07);
            }

    .auth-message {
        display: none;
        padding: 9px 13px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 500;
        margin-bottom: 12px;
    }

        .auth-message.error {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
            display: block;
        }

        .auth-message.success {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
            display: block;
        }

    .auth-submit {
        width: 100%;
        padding: 11px;
        background: #6b1a1a;
        color: #fff;
        font-size: 0.92rem;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        margin-top: 6px;
        transition: background 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .auth-submit:hover {
            background: #8b2a2a;
        }

        .auth-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .auth-switch {
        text-align: center;
        font-size: 0.78rem;
        color: #aaa;
        margin-top: 14px;
    }

        .auth-switch a {
            color: #6b1a1a;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }

            .auth-switch a:hover {
                text-decoration: underline;
            }

    .spinner {
        display: inline-block;
        width: 13px;
        height: 13px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        vertical-align: middle;
        margin-right: 6px;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div id="authOverlay">
    <div class="auth-card">
        <button class="auth-close" onclick="closeAuthModal()">&times;</button>
        <div class="auth-tabs">
            <button class="auth-tab active" id="tab-signin" onclick="switchTab('signin')">Sign In</button>
            <button class="auth-tab" id="tab-signup" onclick="switchTab('signup')">Sign Up</button>
        </div>
        <div class="auth-panels">

            <!-- SIGN IN -->
            <div class="auth-panel active" id="panel-signin">
                <h2>Welcome back</h2>
                <p class="sub">Sign in to your account to continue</p>
                <div class="role-toggle">
                    <button class="role-btn active" id="si-role-citizen" onclick="setSignInRole('Citizen')">
                        <i class="fa-solid fa-user" style="font-size:0.75rem"></i> Citizen
                    </button>
                    <button class="role-btn" id="si-role-organizer" onclick="setSignInRole('Organizer')">
                        <i class="fa-solid fa-id-badge" style="font-size:0.75rem"></i> Organizer
                    </button>
                </div>
                <div class="auth-message" id="signin-msg"></div>
                <div class="auth-group">
                    <label>Email</label>
                    <input type="email" id="si-email" placeholder="you@example.com" />
                </div>
                <div class="auth-group">
                    <label>Password</label>
                    <input type="password" id="si-password" placeholder="••••••••" />
                </div>
                <button class="auth-submit" id="si-btn" onclick="handleSignIn()">Sign In</button>
                <div class="auth-switch">
                    Don't have an account? <a onclick="switchTab('signup')">Sign Up</a>
                </div>
            </div>

            <!-- SIGN UP -->
            <div class="auth-panel" id="panel-signup">
                <h2>Create account</h2>
                <p class="sub">Join us — it only takes a minute</p>
                <div class="role-toggle">
                    <button class="role-btn active" id="su-role-citizen" onclick="setSignUpRole('Citizen')">
                        <i class="fa-solid fa-user" style="font-size:0.75rem"></i> Citizen
                    </button>
                    <button class="role-btn" id="su-role-organizer" onclick="setSignUpRole('Organizer')">
                        <i class="fa-solid fa-id-badge" style="font-size:0.75rem"></i> Organizer
                    </button>
                </div>
                <div class="auth-message" id="signup-msg"></div>
                <div class="auth-group">
                    <label>Full Name</label>
                    <input type="text" id="su-name" placeholder="John Doe" />
                </div>
                <div class="auth-group">
                    <label>Email</label>
                    <input type="email" id="su-email" placeholder="you@example.com" />
                </div>
                <div class="auth-group" id="su-phone-group">
                    <label>Phone</label>
                    <input type="tel" id="su-phone" placeholder="+94 77 123 4567" />
                </div>
                <div class="auth-group" id="su-org-group" style="display:none">
                    <label>Organization Name</label>
                    <input type="text" id="su-org" placeholder="Your organization" />
                </div>
                <div class="auth-group">
                    <label>Password</label>
                    <input type="password" id="su-password" placeholder="Create a password" />
                </div>
                <button class="auth-submit" id="su-btn" onclick="handleSignUp()">Create Account</button>
                <div class="auth-switch">
                    Already have an account? <a onclick="switchTab('signin')">Sign In</a>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    let siRole = 'Citizen';
    let suRole = 'Citizen';

    function openAuthModal(tab) {
        document.getElementById('authOverlay').classList.add('open');
        switchTab(tab || 'signin');
        clearMessages();
    }
    function closeAuthModal() {
        document.getElementById('authOverlay').classList.remove('open');
        clearMessages();
        clearInputs();
    }
    document.getElementById('authOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeAuthModal();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAuthModal(); });

    function switchTab(tab) {
        ['signin','signup'].forEach(t => {
            document.getElementById('panel-' + t).classList.toggle('active', t === tab);
            document.getElementById('tab-'    + t).classList.toggle('active', t === tab);
        });
        clearMessages();
    }

    function setSignInRole(role) {
        siRole = role;
        document.getElementById('si-role-citizen').classList.toggle('active',   role === 'Citizen');
        document.getElementById('si-role-organizer').classList.toggle('active', role === 'Organizer');
    }
    function setSignUpRole(role) {
        suRole = role;
        document.getElementById('su-role-citizen').classList.toggle('active',   role === 'Citizen');
        document.getElementById('su-role-organizer').classList.toggle('active', role === 'Organizer');
        document.getElementById('su-phone-group').style.display = role === 'Citizen'   ? '' : 'none';
        document.getElementById('su-org-group').style.display   = role === 'Organizer' ? '' : 'none';
    }

    function showMsg(id, type, text) {
        const el = document.getElementById(id);
        el.className = 'auth-message ' + type;
        el.textContent = text;
    }
    function clearMessages() {
        ['signin-msg','signup-msg'].forEach(id => {
            const el = document.getElementById(id);
            el.className = 'auth-message';
            el.textContent = '';
        });
    }
    function clearInputs() {
        ['si-email','si-password','su-name','su-email','su-phone','su-org','su-password']
            .forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    }
    function setLoading(btnId, loading, label) {
        const btn = document.getElementById(btnId);
        btn.disabled  = loading;
        btn.innerHTML = loading ? '<span class="spinner"></span>Please wait…' : label;
    }

    async function handleSignIn() {
        const email    = document.getElementById('si-email').value.trim();
        const password = document.getElementById('si-password').value;
        if (!email || !password) { showMsg('signin-msg', 'error', 'Please fill in all fields.'); return; }

        setLoading('si-btn', true, 'Sign In');
        try {
            const fd = new FormData();
            fd.append('typedEmail',    email);
            fd.append('typedPassword', password);
            fd.append('selectedRole',  siRole);

            const res = await fetch('/Signin', { method: 'POST', body: fd });
            if (!res.ok) { showMsg('signin-msg', 'error', 'Server error: ' + res.status); return; }

            const out = await res.json();
            if (!out.ok) { showMsg('signin-msg', 'error', out.message || 'Invalid email or password.'); return; }

            showMsg('signin-msg', 'success', 'Signed in! Loading…');
            setTimeout(() => { closeAuthModal(); location.reload(); }, 800);
        } catch(e) {
            showMsg('signin-msg', 'error', 'Could not reach the server.');
        } finally {
            setLoading('si-btn', false, 'Sign In');
        }
    }

    async function handleSignUp() {
        const name     = document.getElementById('su-name').value.trim();
        const email    = document.getElementById('su-email').value.trim();
        const password = document.getElementById('su-password').value;
        const phone    = document.getElementById('su-phone').value.trim();
        const org      = document.getElementById('su-org').value.trim();

        if (!name || !email || !password) { showMsg('signup-msg', 'error', 'Name, email and password are required.'); return; }
        if (suRole === 'Citizen'   && !phone) { showMsg('signup-msg', 'error', 'Phone number is required.');       return; }
        if (suRole === 'Organizer' && !org)   { showMsg('signup-msg', 'error', 'Organization name is required.'); return; }

        setLoading('su-btn', true, 'Create Account');
        try {
            const fd = new FormData();
            fd.append('enteredName',     name);
            fd.append('enteredEmail',    email);
            fd.append('enteredPassword', password);
            fd.append('enteredPhone',    phone);
            fd.append('enteredOrg',      org);
            fd.append('selectedRole',    suRole);

            const res = await fetch('/Signup', { method: 'POST', body: fd });
            if (!res.ok) { showMsg('signup-msg', 'error', 'Server error: ' + res.status); return; }

            const out = await res.json();
            if (!out.ok) { showMsg('signup-msg', 'error', out.message || 'Registration failed.'); return; }

            showMsg('signup-msg', 'success', 'Account created! Loading…');
            setTimeout(() => { closeAuthModal(); location.reload(); }, 900);
        } catch(e) {
            showMsg('signup-msg', 'error', 'Could not reach the server.');
        } finally {
            setLoading('su-btn', false, 'Create Account');
        }
    }
</script>