@page
@model Web1.Pages.AboutModel
@{
    ViewData["Title"] = "About Us";
}

@section Styles {
    <style>
       

        :root {
            --g1: #0f3d1f;
            --g2: #0a2e16;
            --g3: #1a5c30;
            --g4: #2d8a4e;
            --lime: #86efac;
            --cream: #f5f0e8;
            --ink: #0d1f12;
            --muted: #5a7a62;
            --border: rgba(15,61,31,0.14);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--cream);
            color: var(--ink);
            overflow-x: hidden;
        }

        /* ── HERO ── */
        .about-hero {
            background: var(--g2);
            padding: 7rem 0 5rem;
            position: relative;
            overflow: hidden;
        }

            .about-hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(134,239,172,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(134,239,172,0.04) 1px, transparent 1px);
                background-size: 60px 60px;
            }

            /* large background text */
            .about-hero::after {
                content: 'ABOUT';
                position: absolute;
                bottom: -2rem;
                right: -1rem;
                font-family: 'Cormorant Garamond', serif;
                font-size: 16rem;
                font-weight: 700;
                color: rgba(255,255,255,0.025);
                line-height: 1;
                pointer-events: none;
                letter-spacing: -0.02em;
            }

        .about-hero-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2.5rem;
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: end;
        }

        .about-hero-tag {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            color: var(--lime);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .about-hero-tag::before {
                content: '';
                display: block;
                width: 30px;
                height: 1px;
                background: var(--lime);
            }

        .about-hero h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 5.5vw, 6rem);
            font-weight: 600;
            color: white;
            line-height: 0.95;
        }

            .about-hero h1 em {
                font-style: italic;
                color: var(--lime);
            }

        .about-hero-right {
            padding-bottom: 0.5rem;
        }

            .about-hero-right p {
                font-size: 0.95rem;
                color: rgba(255,255,255,0.5);
                line-height: 1.85;
                font-weight: 300;
                margin-bottom: 2rem;
            }

        .about-pill-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .about-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1px solid rgba(134,239,172,0.2);
            border-radius: 2px;
            padding: 6px 14px;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
        }

            .about-pill i {
                color: var(--lime);
                font-size: 0.65rem;
            }

        /* ── STORY ── */
        .story-section {
            padding: 7rem 0;
            background: var(--cream);
        }

        .story-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2.5rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            align-items: center;
        }

        .story-img-wrap {
            position: relative;
        }

        .story-img {
            width: 100%;
            height: 480px;
            object-fit: cover;
            display: block;
            filter: grayscale(20%) contrast(1.05);
            border: 1px solid var(--border);
        }

        .story-img-badge {
            position: absolute;
            bottom: -1.5rem;
            right: -1.5rem;
            background: var(--g1);
            color: white;
            padding: 1.5rem 2rem;
            text-align: center;
            border: 1px solid rgba(134,239,172,0.15);
        }

        .story-img-badge-num {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.8rem;
            font-weight: 700;
            color: var(--lime);
            line-height: 1;
            display: block;
        }

        .story-img-badge-label {
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.45);
            display: block;
            margin-top: 4px;
        }

        .story-tag {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            color: var(--g3);
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .story-tag::before {
                content: '';
                display: block;
                width: 24px;
                height: 1px;
                background: var(--g3);
            }

        .story-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 3vw, 3rem);
            font-weight: 600;
            color: var(--ink);
            line-height: 1.05;
            margin-bottom: 1.5rem;
        }

            .story-title em {
                font-style: italic;
                color: var(--g3);
            }

        .story-body {
            font-size: 0.9rem;
            color: var(--muted);
            line-height: 1.9;
            font-weight: 300;
            margin-bottom: 1rem;
        }

        /* ── VALUES ── */
        .values-section {
            background: var(--g2);
            padding: 7rem 0;
            position: relative;
            overflow: hidden;
        }

            .values-section::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(134,239,172,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(134,239,172,0.03) 1px, transparent 1px);
                background-size: 80px 80px;
            }

        .values-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2.5rem;
            position: relative;
            z-index: 1;
        }

        .values-top {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: end;
            margin-bottom: 4rem;
        }

        .values-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 3.5vw, 3.5rem);
            font-weight: 600;
            color: white;
            line-height: 1.0;
        }

            .values-title em {
                font-style: italic;
                color: var(--lime);
            }

        .values-desc {
            font-size: 0.875rem;
            color: rgba(255,255,255,0.4);
            line-height: 1.85;
            font-weight: 300;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1px;
            background: rgba(134,239,172,0.07);
        }

        .value-item {
            background: var(--g2);
            padding: 2.5rem 2rem;
            border-top: 2px solid transparent;
            transition: all 0.22s;
        }

            .value-item:hover {
                background: rgba(134,239,172,0.04);
                border-top-color: var(--lime);
            }

        .value-icon {
            width: 42px;
            height: 42px;
            border: 1px solid rgba(134,239,172,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--lime);
            font-size: 0.9rem;
            margin-bottom: 1.4rem;
            border-radius: 2px;
            transition: background 0.22s;
        }

        .value-item:hover .value-icon {
            background: rgba(134,239,172,0.1);
        }

        .value-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            font-weight: 600;
            color: white;
            margin-bottom: 0.6rem;
        }

        .value-desc {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.35);
            line-height: 1.8;
            font-weight: 300;
        }

        /* ── CONTACT ── */
        .contact-section {
            background: var(--cream);
            padding: 7rem 0;
        }

        .contact-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2.5rem;
        }

        .contact-top {
            text-align: center;
            margin-bottom: 4rem;
        }

        .contact-tag {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            color: var(--g3);
            margin-bottom: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .contact-tag::before,
            .contact-tag::after {
                content: '';
                display: block;
                width: 30px;
                height: 1px;
                background: var(--g3);
            }

        .contact-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 3.5vw, 3.2rem);
            font-weight: 600;
            color: var(--ink);
            line-height: 1.05;
        }

            .contact-title em {
                font-style: italic;
                color: var(--g3);
            }

        .contact-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
        }

        .contact-item {
            background: var(--cream);
            padding: 2.5rem 2rem;
            text-align: center;
            transition: background 0.22s;
        }

            .contact-item:hover {
                background: white;
            }

        .contact-item-icon {
            width: 48px;
            height: 48px;
            border: 1px solid var(--border);
            border-radius: 2px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--g3);
            font-size: 1rem;
            margin: 0 auto 1.2rem;
            transition: all 0.22s;
        }

        .contact-item:hover .contact-item-icon {
            background: var(--g1);
            color: var(--lime);
            border-color: var(--g1);
        }

        .contact-item-label {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 0.5rem;
        }

        .contact-item-value {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--ink);
            line-height: 1.4;
        }

        .contact-item-sub {
            font-size: 0.75rem;
            color: var(--muted);
            margin-top: 4px;
            font-weight: 300;
        }

        /* FADE */
        .fade-up {
            opacity: 0;
            transform: translateY(28px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }

            .fade-up.visible {
                opacity: 1;
                transform: translateY(0);
            }

  
    </style>
}

<!-- HERO -->
<section class="about-hero">
    <div class="about-hero-inner">
        <div>
            <div class="about-hero-tag">Who We Are</div>
            <h1>
                Crafting<br>
                <em>Moments</em><br>
                That Matter.
            </h1>
        </div>
        <div class="about-hero-right">
            <p>
                Chamoth Event Organizers is a dedicated event management platform built
                to connect communities through meaningful, well-executed experiences.
                We believe every event — large or small — deserves to be extraordinary.
            </p>
            <div class="about-pill-row">
                <span class="about-pill"><i class="fa-solid fa-check"></i> Trusted Organizers</span>
                <span class="about-pill"><i class="fa-solid fa-check"></i> Community Focused</span>
                <span class="about-pill"><i class="fa-solid fa-check"></i> 8 Event Categories</span>
                <span class="about-pill"><i class="fa-solid fa-check"></i> Est. 2010</span>
            </div>
        </div>
    </div>
</section>

<!-- STORY -->
<section class="story-section fade-up">
    <div class="story-inner">
        <div class="story-img-wrap">
            <img class="story-img"
                 src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=800&q=80"
                 alt="Event crowd" />
            <div class="story-img-badge">
                <span class="story-img-badge-num">15+</span>
                <span class="story-img-badge-label">Years of Experience</span>
            </div>
        </div>
        <div>
            <div class="story-tag">Our Story</div>
            <h2 class="story-title">
                From a small idea<br>
                to a <em>thriving platform.</em>
            </h2>
            <p class="story-body">
                Founded in 2010, Chamoth Event Organizers started as a small local team
                passionate about bringing people together. Over fifteen years, we have grown
                into a full-scale digital event platform serving thousands of attendees and
                hundreds of organizers across the region.
            </p>
            <p class="story-body">
                Our platform is built on the belief that great events don't happen by accident —
                they are planned with care, managed with precision, and executed with heart.
                Every feature we build, every process we refine, is in service of that belief.
            </p>
        </div>
    </div>
</section>

<!-- VALUES -->
<section class="values-section fade-up">
    <div class="values-inner">
        <div class="values-top">
            <h2 class="values-title">
                What we<br>
                stand <em>for.</em>
            </h2>
            <p class="values-desc">
                Our values are not slogans — they are the principles that guide
                every decision we make, every event we host, and every community we serve.
            </p>
        </div>
        <div class="values-grid">
            <div class="value-item">
                <div class="value-icon"><i class="fa-solid fa-shield-halved"></i></div>
                <div class="value-title">Integrity</div>
                <div class="value-desc">We operate with full transparency — every event, every registration, every decision is handled with honesty and accountability.</div>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fa-solid fa-people-group"></i></div>
                <div class="value-title">Community</div>
                <div class="value-desc">We exist to serve communities — creating spaces where people connect, celebrate and grow together meaningfully.</div>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fa-solid fa-bullseye"></i></div>
                <div class="value-title">Precision</div>
                <div class="value-desc">Details matter. From capacity management to timing — we execute every event with meticulous attention to quality.</div>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fa-solid fa-universal-access"></i></div>
                <div class="value-title">Accessibility</div>
                <div class="value-desc">Every feature we build is designed to be usable by everyone — regardless of technical ability or background.</div>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fa-solid fa-seedling"></i></div>
                <div class="value-title">Growth</div>
                <div class="value-desc">We continuously evolve — improving our platform, expanding our reach, and learning from every event we run.</div>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fa-solid fa-handshake"></i></div>
                <div class="value-title">Partnership</div>
                <div class="value-desc">We work hand-in-hand with organizers — not just as a tool, but as a committed partner in their event's success.</div>
            </div>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section class="contact-section fade-up">
    <div class="contact-inner">
        <div class="contact-top">
            <div class="contact-tag">Get In Touch</div>
            <h2 class="contact-title">
                We are always<br><em>here for you.</em>
            </h2>
        </div>
        <div class="contact-grid">
            <div class="contact-item">
                <div class="contact-item-icon"><i class="fa-solid fa-location-dot"></i></div>
                <div class="contact-item-label">Address</div>
                <div class="contact-item-value">Chamoth Event Organizers</div>
                <div class="contact-item-sub">Kandy, Sri Lanka</div>
            </div>
            <div class="contact-item">
                <div class="contact-item-icon"><i class="fa-solid fa-phone"></i></div>
                <div class="contact-item-label">Phone</div>
                <div class="contact-item-value">+94 77 000 0000</div>
                <div class="contact-item-sub">Mon – Fri, 9am – 5pm</div>
            </div>
            <div class="contact-item">
                <div class="contact-item-icon"><i class="fa-solid fa-envelope"></i></div>
                <div class="contact-item-label">Email</div>
                <div class="contact-item-value">hello@chamoth.lk</div>
                <div class="contact-item-sub">Reply within 24 hours</div>
            </div>
            <div class="contact-item">
                <div class="contact-item-icon"><i class="fa-solid fa-clock"></i></div>
                <div class="contact-item-label">Office Hours</div>
                <div class="contact-item-value">Mon – Fri</div>
                <div class="contact-item-sub">9:00 AM – 5:00 PM</div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.08 });

        document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
}